pipeline {
    agent any
    stages {
        stage('Approval') {
            steps {
                input message: 'Approve production deployment?'
            }
        }
        stage('Deploy to Prod') {
            steps {
                sh 'helm upgrade --install ecom-ai-prod devops/helm/ecommerce-ai -f devops/helm/ecommerce-ai/values-prod.yaml --namespace production --create-namespace'
            }
        }
    }
}
