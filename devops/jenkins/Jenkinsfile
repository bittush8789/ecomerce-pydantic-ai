pipeline {
    agent any
    stages {
        stage('Checkout') { steps { checkout scm } }
        stage('Lint & Test') {
            parallel {
                stage('Bandit') { steps { sh 'bandit -r .' } }
                stage('Safety') { steps { sh 'safety check' } }
                stage('Gitleaks') { steps { sh 'gitleaks detect --source . -v' } }
            }
        }
        stage('Build') {
            steps {
                sh 'docker build -t ecom-ai:latest -f devops/docker/Dockerfile.backend .'
            }
        }
    }
}
